{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended"
  ],
  "ignorePaths": [
    "**/testdata/**/*.html"
  ],
  "timezone": "Asia/Tokyo",
  "minimumReleaseAge": "2 days",
  "osvVulnerabilityAlerts": true,
  "postUpdateOptions": [
    "gomodTidy"
  ],
  "packageRules": [
    {
      "matchManagers": [
        "dockerfile"
      ],
      "matchPackageNames": [
        "ghcr.io/jdx/mise"
      ],
      "enabled": false
    },
    {
      "matchManagers": [
        "gomod"
      ],
      "matchUpdateTypes": [
        "minor",
        "patch"
      ],
      "groupName": "dependencies",
      "schedule": [
        "on the first day of the month"
      ]
    },
    {
      "matchManagers": [
        "github-actions"
      ],
      "matchUpdateTypes": [
        "minor",
        "patch"
      ],
      "groupName": "actions",
      "schedule": [
        "on the first day of the month"
      ]
    }
  ]
}
