{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended"
  ],
  "timezone": "Asia/Tokyo",
  "minimumReleaseAge": "1 days",
  "osvVulnerabilityAlerts": true,
  "packageRules": [
    {
      "matchManagers": [
        "gomod"
      ],
      "matchUpdateTypes": [
        "minor",
        "patch"
      ],
      "groupName": "dependencies",
      "schedule": [
        "on the first day of the month"
      ]
    },
    {
      "matchManagers": [
        "github-actions"
      ],
      "matchUpdateTypes": [
        "minor",
        "patch"
      ],
      "groupName": "actions",
      "schedule": [
        "on the first day of the month"
      ]
    },
    {
      "matchDatasources": [
        "docker",
        "golang-version"
      ],
      "matchPackageNames": [
        "golang",
        "go"
      ],
      "groupName": "go",
      "schedule": [
        "on the first day of the month"
      ]
    }
  ]
}
